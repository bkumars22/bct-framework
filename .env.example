# Copy this file to .env (already gitignored) and fill in one real key.
# api/main.py loads .env automatically on startup — no shell export needed.
#
# With a key set, /verify (and the dashboard) run REAL verification: an
# actual LLM call per test case plus an LLM judge call, instead of the
# probability-table simulation. Only one of these is required.

GROQ_API_KEY=
ANTHROPIC_API_KEY=
